# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Per-product pricing (Option A: lenses $30 each, Cosmic Bundle $99.99)
STRIPE_PRICE_ID_COSMIC_BUNDLE=price_...
STRIPE_PRICE_ID_PERSONAL_LIFESTYLE=price_...
STRIPE_PRICE_ID_STUDENT_SUCCESS=price_...
STRIPE_PRICE_ID_PROFESSIONAL_LEADERSHIP=price_...
STRIPE_PRICE_ID_FAMILY_ECOSYSTEM=price_...

# ─── Resend (Email) ─────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
FROM_EMAIL=BEST Galaxy <noreply@bestgalaxy.com>
FRONTEND_URL=http://localhost:3000

# ─── Token Signing ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
TOKEN_SECRET=

# ─── Admin ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=

# ─── CORS (set after frontend is deployed to Cloud Run) ──────────────────────
# Comma-separated list of allowed frontend origins, e.g.:
#   ALLOWED_ORIGINS=https://best-galaxy-frontend-xyz-uc.a.run.app
# Leave empty (or omit) to allow all origins during development.
ALLOWED_ORIGINS=
